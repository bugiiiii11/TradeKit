# Hyperliquid API wallet private key (0x-prefixed, 64 hex chars)
# This is the API wallet key generated at app.hyperliquid.xyz → API tab.
# It can trade but CANNOT withdraw funds. NEVER commit the real .env file.
HYPERLIQUID_PRIVATE_KEY=0xyour_api_wallet_private_key_here

# Your main MetaMask wallet address (the account that holds USDC on Hyperliquid)
HYPERLIQUID_WALLET_ADDRESS=0xyour_main_wallet_address_here

# Hyperliquid network: "mainnet" or "testnet"
HYPERLIQUID_NETWORK=mainnet

# Starting bankroll in USD (used for risk calculations)
BANKROLL=500

# Loop interval in milliseconds (default: 15 minutes)
LOOP_INTERVAL_MS=900000

SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

SUPABASE_URL=https://your-project-ref.supabase.co